# SonicBoom Environment Configuration Example

# --- Server Configuration ---
# Server port
PORT=3000
# Admin panel username
SONICBOOM_ADMIN_ID=admin
# Admin panel password
SONICBOOM_ADMIN_PW=1234

# --- Model Configuration ---
# Directory where models will be downloaded and cached
MODEL_CACHE_DIR=./models
# HuggingFace token for private models (optional if models are public)
HF_TOKEN=your_huggingface_token_here
# Number of inference steps (1-3: Low/Fast, 5: Medium, 10: High, 20+: Very High)
INFERENCE_STEPS=5

# --- Security ---
# Path to the JSON file storing API tokens
TOKEN_STORE_PATH=./tokens.json
# Enable a sample token for testing purposes (true/1 or false/0)
ENABLE_SAMPLE_TOKEN=false
# Set to false to allow API access without authentication
# (Uses true/1 for enabled, false/0 for disabled)
SONICBOOM_AUTH_REQUIRED=true

# --- Logging ---
# Directory for log files
LOG_DIR=./logs
# Log level: debug, info, warn, error
LOG_LEVEL=info
# Enable/disable logging to file
LOG_TO_FILE=true
# Enable/disable logging to standard output
LOG_TO_STDOUT=true
